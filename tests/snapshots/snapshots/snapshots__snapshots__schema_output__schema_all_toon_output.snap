      id.type: string
      issue_type:
        "$ref": #/$defs/IssueType
      priority:
        "$ref": #/$defs/Priority
      status:
        "$ref": #/$defs/Status
      title.type: string
      updated_at:
        type: string
        format: date-time
      assignee.type[2]: string,"null"
    required[7]: created_at,id,issue_type,priority,status,title,updated_at
    "$defs":
      IssueType:
        description: Issue type category.
        anyOf[2]:
          - type: string
            enum[7]: task,bug,feature,epic,chore,docs,question
          - type: string
      Priority:
        description: "Issue priority (0=Critical, 4=Backlog)."
        type: integer
        format: int32
      Status:
        description: Issue lifecycle status.
        anyOf[2]:
          - type: string
            enum[8]: open,in_progress,blocked,deferred,draft,closed,tombstone,pinned
          - type: string
  Statistics:
    "$schema": "https://json-schema.org/draft/2020-12/schema"
    title: Statistics
    description: Aggregate statistics output.
    type: object
    properties:
      summary:
        "$ref": #/$defs/StatsSummary
      breakdowns:
        type: array
        items:
          "$ref": #/$defs/Breakdown
      recent_activity.anyOf[2]:
        - "$ref": #/$defs/RecentActivity
        - type: "null"
    required[2]: summary,breakdowns
    "$defs":
      StatsSummary:
        description: Summary statistics for the project.
        type: object
        properties:
          total_issues:
            type: integer
            format: uint
            minimum: 0
          open_issues:
            type: integer
            format: uint
            minimum: 0
          in_progress_issues:
            type: integer
            format: uint
            minimum: 0
          closed_issues:
            type: integer
            format: uint
            minimum: 0
          blocked_issues:
            type: integer
            format: uint
            minimum: 0
          deferred_issues:
            type: integer
            format: uint
            minimum: 0
          draft_issues:
            type: integer
            format: uint
            minimum: 0
          ready_issues:
            type: integer
            format: uint
            minimum: 0
          tombstone_issues:
            type: integer
            format: uint
            minimum: 0
          pinned_issues:
            type: integer
            format: uint
            minimum: 0
          epics_eligible_for_closure:
            type: integer
            format: uint
            minimum: 0
          average_lead_time_hours:
            type[2]: number,"null"
            format: double
        required[11]: total_issues,open_issues,in_progress_issues,closed_issues,blocked_issues,deferred_issues,draft_issues,ready_issues,tombstone_issues,pinned_issues,epics_eligible_for_closure
      Breakdown:
        description: Breakdown statistics by a dimension.
        type: object
        properties:
          dimension.type: string
          counts:
            type: array
            items:
              "$ref": #/$defs/BreakdownEntry
        required[2]: dimension,counts
      BreakdownEntry:
        description: A single entry in a breakdown.
        type: object
        properties:
          key.type: string
          count:
            type: integer
            format: uint
            minimum: 0
        required[2]: key,count
      RecentActivity:
        description: Recent activity statistics from git history.
        type: object
        properties:
          hours_tracked:
            type: integer
            format: uint32
            minimum: 0
          commit_count:
            type: integer
            format: uint
            minimum: 0
          issues_created:
            type: integer
            format: uint
            minimum: 0
          issues_closed:
            type: integer
            format: uint
            minimum: 0
          issues_updated:
            type: integer
            format: uint
            minimum: 0
          issues_reopened:
            type: integer
            format: uint
            minimum: 0
          total_changes:
            type: integer
            format: uint
            minimum: 0
        required[7]: hours_tracked,commit_count,issues_created,issues_closed,issues_updated,issues_reopened,total_changes
  TreeNode:
    "$schema": "https://json-schema.org/draft/2020-12/schema"
    title: TreeNode
    description: Tree node for dependency tree view.
    type: object
    properties:
      id:
        description: "Unique ID (e.g., \"bd-abc123\")."
        type: string
      title:
        description: Title (1-500 chars).
        type: string
      description:
        description: Detailed description.
        type[2]: string,"null"
      design:
        description: Technical design notes.
        type[2]: string,"null"
      acceptance_criteria:
        description: Acceptance criteria.
        type[2]: string,"null"
      notes:
        description: Additional notes.
        type[2]: string,"null"
      status:
        description: Workflow status.
        "$ref": #/$defs/Status
        default: open
      priority:
        description: "Priority (0=Critical, 4=Backlog)."
        "$ref": #/$defs/Priority
        default: 2
      issue_type:
        description: "Issue type (bug, feature, etc.)."
        "$ref": #/$defs/IssueType
        default: task
      assignee:
        description: Assigned user.
        type[2]: string,"null"
      owner:
        description: Issue owner.
        type[2]: string,"null"
      estimated_minutes:
        description: Estimated effort in minutes.
        type[2]: integer,"null"
        format: int32
      created_at:
        description: Creation timestamp.
        type: string
        format: date-time
      created_by:
        description: Creator username.
        type[2]: string,"null"
      updated_at:
        description: Last update timestamp.
        type: string
        format: date-time
      closed_at:
        description: Closure timestamp.
        type[2]: string,"null"
        format: date-time
      close_reason:
        description: Reason for closure.
        type[2]: string,"null"
      closed_by_session:
        description: Session ID that closed this issue.
        type[2]: string,"null"
      due_at:
        description: Due date.
        type[2]: string,"null"
        format: date-time
      defer_until:
        description: Defer until date.
        type[2]: string,"null"
        format: date-time
      external_ref:
        description: "External reference (e.g., JIRA-123)."
        type[2]: string,"null"
      source_system:
        description: Source system for imported issues.
        type[2]: string,"null"
      source_repo:
        description: Source repository for multi-repo support.
        type[2]: string,"null"
      deleted_at:
        type[2]: string,"null"
        format: date-time
      deleted_by.type[2]: string,"null"
      delete_reason.type[2]: string,"null"
      original_type.type[2]: string,"null"
      compaction_level:
        type[2]: integer,"null"
        format: int32
        default: 0
      compacted_at:
        type[2]: string,"null"
        format: date-time
      compacted_at_commit.type[2]: string,"null"
      original_size:
        type[2]: integer,"null"
        format: int32
      sender.type[2]: string,"null"
      ephemeral.type: boolean
      pinned.type: boolean
      is_template.type: boolean
      labels:
        type: array
        items.type: string
      dependencies:
        type: array
        items:
          "$ref": #/$defs/Dependency
      comments:
        type: array
        items:
          "$ref": #/$defs/Comment
      depth:
        type: integer
        format: uint
        minimum: 0
      parent_id.type[2]: string,"null"
      truncated.type: boolean
    required[6]: id,title,created_at,updated_at,depth,truncated
    "$defs":
      Status:
        description: Issue lifecycle status.
        anyOf[2]:
          - type: string
            enum[8]: open,in_progress,blocked,deferred,draft,closed,tombstone,pinned
          - type: string
      Priority:
        description: "Issue priority (0=Critical, 4=Backlog)."
        type: integer
        format: int32
      IssueType:
        description: Issue type category.
        anyOf[2]:
          - type: string
            enum[7]: task,bug,feature,epic,chore,docs,question
          - type: string
      Dependency:
        description: Relationship between two issues.
        type: object
        properties:
          issue_id:
            description: The issue that has the dependency (source).
            type: string
          depends_on_id:
            description: The issue being depended on (target).
            type: string
          type:
            description: Type of dependency.
            "$ref": #/$defs/DependencyType
          created_at:
            description: Creation timestamp.
            type: string
            format: date-time
          created_by:
            description: Creator.
            type[2]: string,"null"
          metadata:
            description: Optional metadata (JSON).
            type[2]: string,"null"
          thread_id:
            description: Thread ID for conversation linking.
            type[2]: string,"null"
        required[4]: issue_id,depends_on_id,type,created_at
      DependencyType:
        description: Dependency relationship type.
        anyOf[2]:
          - type: string
            enum[11]: blocks,parent-child,conditional-blocks,waits-for,related,discovered-from,replies-to,relates-to,duplicates,supersedes,caused-by
          - type: string
      Comment:
        description: A comment on an issue.
        type: object
        properties:
          id:
            type: integer
            format: int64
          issue_id.type: string
          author.type: string
          text.type: string
          created_at:
            type: string
            format: date-time
        required[5]: id,issue_id,author,text,created_at
commands:
  blocked:
    shape: array
    jq_filter: ".[]"
    items_at: .
    item_schema: BlockedIssue
    error_envelope_on_stderr: false
  "comments list":
    shape: array
    jq_filter: ".[]"
    items_at: .
    error_envelope_on_stderr: true
    notes: Empty array if no comments. ErrorEnvelope on stderr if the issue id cannot be resolved.
  count:
    shape: object
    jq_filter: .count
    error_envelope_on_stderr: false
    notes: Scalar count under `.count`.
  "dep list":
    shape: array
    jq_filter: ".[]"
    items_at: .
    error_envelope_on_stderr: true
  "dep tree":
    shape: array
    jq_filter: ".[]"
    items_at: .
    item_schema: TreeNode
    error_envelope_on_stderr: true
    notes: Pre-order traversal; each node carries a `depth` field.
  info:
    shape: object
    jq_filter: .
    error_envelope_on_stderr: false
    notes: "Workspace info object (paths, mode, config snapshot)."
  "label list":
    shape: array
    jq_filter: ".[]"
    items_at: .
    error_envelope_on_stderr: false
  list:
    shape: object
    jq_filter: ".issues[]"
    items_at: .issues
    item_schema: IssueWithCounts
    error_envelope_on_stderr: false
    notes: "Wrapper object with pagination metadata; iterate with `.issues[]`. The wrapper exists so totals/cursors can ride alongside the rows."
  ready:
    shape: array
    jq_filter: ".[]"
    items_at: .
    item_schema: ReadyIssue
    error_envelope_on_stderr: false
  search:
    shape: array
    jq_filter: ".[]"
    items_at: .
    item_schema: IssueWithCounts
    error_envelope_on_stderr: false
  show:
    shape: array
    jq_filter: ".[0]"
    items_at: .
    item_schema: IssueDetails
    error_envelope_on_stderr: true
    notes: "Always a single-element array on success (wrapped for shape consistency with list-style commands). On a missing id, an ErrorEnvelope is written to stderr and exit code is non-zero."
  stale:
    shape: array
    jq_filter: ".[]"
    items_at: .
    item_schema: StaleIssue
    error_envelope_on_stderr: false
  stats:
    shape: object
    jq_filter: .
    item_schema: Statistics
    error_envelope_on_stderr: false
    notes: Single aggregate object.
  status:
    shape: object
    jq_filter: .
    item_schema: Statistics
    error_envelope_on_stderr: false
    notes: Alias for `stats` — identical envelope.
