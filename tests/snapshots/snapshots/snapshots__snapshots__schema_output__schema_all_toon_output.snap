---
tool: br
generated_at: "GENERATED_AT"
schemas:
  BlockedIssue:
    "$schema": "https://json-schema.org/draft/2020-12/schema"
    title: BlockedIssue
    description: Blocked issue for blocked view.
    type: object
    properties:
      id:
        description: "Unique ID (e.g., \"bd-abc123\")."
        type: string
      title:
        description: Title (1-500 chars).
        type: string
      description:
        description: Detailed description.
        type[2]: string,"null"
      design:
        description: Technical design notes.
        type[2]: string,"null"
      acceptance_criteria:
        description: Acceptance criteria.
        type[2]: string,"null"
      notes:
        description: Additional notes.
        type[2]: string,"null"
      status:
        description: Workflow status.
        "$ref": #/$defs/Status
        default: open
      priority:
        description: "Priority (0=Critical, 4=Backlog)."
        "$ref": #/$defs/Priority
        default: 2
      issue_type:
        description: "Issue type (bug, feature, etc.)."
        "$ref": #/$defs/IssueType
        default: task
      assignee:
        description: Assigned user.
        type[2]: string,"null"
      owner:
        description: Issue owner.
        type[2]: string,"null"
      estimated_minutes:
        description: Estimated effort in minutes.
        type[2]: integer,"null"
        format: int32
      created_at:
        description: Creation timestamp.
        type: string
        format: date-time
      created_by:
        description: Creator username.
        type[2]: string,"null"
      updated_at:
        description: Last update timestamp.
        type: string
        format: date-time
      closed_at:
        description: Closure timestamp.
        type[2]: string,"null"
        format: date-time
      close_reason:
        description: Reason for closure.
        type[2]: string,"null"
      closed_by_session:
        description: Session ID that closed this issue.
        type[2]: string,"null"
      due_at:
        description: Due date.
        type[2]: string,"null"
        format: date-time
      defer_until:
        description: Defer until date.
        type[2]: string,"null"
        format: date-time
      external_ref:
        description: "External reference (e.g., JIRA-123)."
        type[2]: string,"null"
      source_system:
        description: Source system for imported issues.
        type[2]: string,"null"
      source_repo:
        description: Source repository for multi-repo support.
        type[2]: string,"null"
      deleted_at:
        type[2]: string,"null"
        format: date-time
      deleted_by.type[2]: string,"null"
      delete_reason.type[2]: string,"null"
      original_type.type[2]: string,"null"
      compaction_level:
        type[2]: integer,"null"
        format: int32
        default: 0
      compacted_at:
        type[2]: string,"null"
        format: date-time
      compacted_at_commit.type[2]: string,"null"
      original_size:
        type[2]: integer,"null"
        format: int32
      sender.type[2]: string,"null"
      ephemeral.type: boolean
      pinned.type: boolean
      is_template.type: boolean
      labels:
        type: array
        items.type: string
      dependencies:
        type: array
        items:
          "$ref": #/$defs/Dependency
      comments:
        type: array
        items:
          "$ref": #/$defs/Comment
      blocked_by_count:
        type: integer
        format: uint
        minimum: 0
      blocked_by:
        type: array
        items.type: string
    required[6]: id,title,created_at,updated_at,blocked_by_count,blocked_by
    "$defs":
      Status:
        description: Issue lifecycle status.
        anyOf[2]:
          - type: string
            enum[8]: open,in_progress,blocked,deferred,draft,closed,tombstone,pinned
          - type: string
      Priority:
        description: "Issue priority (0=Critical, 4=Backlog)."
        type: integer
        format: int32
      IssueType:
        description: Issue type category.
        anyOf[2]:
          - type: string
            enum[7]: task,bug,feature,epic,chore,docs,question
          - type: string
      Dependency:
        description: Relationship between two issues.
        type: object
        properties:
          issue_id:
            description: The issue that has the dependency (source).
            type: string
          depends_on_id:
            description: The issue being depended on (target).
            type: string
          type:
            description: Type of dependency.
            "$ref": #/$defs/DependencyType
          created_at:
            description: Creation timestamp.
            type: string
            format: date-time
          created_by:
            description: Creator.
            type[2]: string,"null"
          metadata:
            description: Optional metadata (JSON).
            type[2]: string,"null"
          thread_id:
            description: Thread ID for conversation linking.
            type[2]: string,"null"
        required[4]: issue_id,depends_on_id,type,created_at
      DependencyType:
        description: Dependency relationship type.
        anyOf[2]:
          - type: string
            enum[11]: blocks,parent-child,conditional-blocks,waits-for,related,discovered-from,replies-to,relates-to,duplicates,supersedes,caused-by
          - type: string
      Comment:
        description: A comment on an issue.
        type: object
        properties:
          id:
            type: integer
            format: int64
          issue_id.type: string
          author.type: string
          text.type: string
          created_at:
            type: string
            format: date-time
        required[5]: id,issue_id,author,text,created_at
  ErrorEnvelope:
    "$schema": "https://json-schema.org/draft/2020-12/schema"
    title: ErrorEnvelope
    type: object
    properties:
      error:
        "$ref": #/$defs/ErrorBody
    required[1]: error
    "$defs":
      ErrorBody:
        type: object
        properties:
          code:
            description: Machine-readable error code (SCREAMING_SNAKE_CASE)
            type: string
          message:
            description: Human-readable message
            type: string
          hint:
            description: Optional hint for remediation
            type[2]: string,"null"
          retryable:
            description: Whether the operation can be retried
            type: boolean
          context.description: Additional context for debugging (arbitrary JSON)
        required[3]: code,message,retryable
